{
	"manifest_version": 3,
	"name": "Loom WebBridge",
	"version": "1.0.0",
	"description": "Lets Loom drive this browser (your real login sessions) via the local WebBridge daemon.",
	"permissions": ["tabs", "scripting", "activeTab", "debugger", "storage", "alarms", "tabGroups"],
	"host_permissions": ["<all_urls>"],
	"background": { "service_worker": "background.js" },
	"action": { "default_title": "Loom WebBridge" }
}
